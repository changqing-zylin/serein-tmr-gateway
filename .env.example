# ==============================================================================
# SEREIN-CORE: ENTERPRISE INFRASTRUCTURE CONFIGURATION
# ARCHITECTURE: TMR CONSENSUS / WASI-VIRT SANDBOX
# ==============================================================================

# ------------------------------------------------------------------------------
# SECTION 1: KERNEL SECURITY & CRYPTOGRAPHY
# ------------------------------------------------------------------------------
# 256-bit AES master key for at-rest encryption (AES-256-GCM)
# MUST be exactly 64 hex characters.
SEREIN_MASTER_KEY=your_64_char_hex_key_here

# HMAC-SHA256 Secret for internal service-to-service authentication
SEREIN_INTERNAL_TOKEN=your_internal_auth_token_here

# ------------------------------------------------------------------------------
# SECTION 2: KERNEL TOPOLOGY & OBSERVABILITY
# ------------------------------------------------------------------------------
APP_ENV=production
APP_NAME=serein-tmr-gateway
APP_VERSION=1.0.0

# Observability: filter for Rust runtime tracing
RUST_LOG=info,serein_core=debug,serein_server=debug

# Concurrency: Tokio async I/O worker threads
WORKER_THREADS=4

# Telemetry: Port for Prometheus metrics scraping
METRICS_PORT=9090

# ------------------------------------------------------------------------------
# SECTION 3: DATABASE & STATE STORE
# ------------------------------------------------------------------------------
# Redis for semantic caching, rate limiting, and FinOps budgeting
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_POOL_SIZE=32

# PostgreSQL for persistent flight records and tenant billing
DATABASE_URL=postgres://serein_user:supersecret@127.0.0.1:5432/serein_db
DB_POOL_SIZE=16

# ------------------------------------------------------------------------------
# SECTION 4: REDIS RATE LIMITING & TOKEN BUDGET (NEXUS MODULE)
# ------------------------------------------------------------------------------
# Default token bucket size per tenant (unless overridden in DB)
DEFAULT_TENANT_BUDGET_USD=100.00
# Alert threshold: fallback to cheap SLM when budget drops below 5%
BUDGET_DEGRADATION_THRESHOLD=0.05
# If true, gateway will allow requests even if Redis/FinOps store is down
FINOPS_BYPASS_ON_FAILURE=true

# ------------------------------------------------------------------------------
# SECTION 5: LLM WAF (SANDBOX GUARD)
# ------------------------------------------------------------------------------
# WAF strict mode: Drop request immediately if Aho-Corasick matches poison payload
WAF_STRICT_MODE=true
# Max size of incoming prompt to scan (prevent regex DOS attacks)
WAF_MAX_PAYLOAD_BYTES=512000 

# ------------------------------------------------------------------------------
# SECTION 6: SOVEREIGN ROUTING & GEOFENCING (LLM ROUTER)
# ------------------------------------------------------------------------------
# Default compliance region (Options: US, EU, CN, GLOBAL)
DEFAULT_COMPLIANCE_REGION=GLOBAL
# Enforce strict geo-fencing (Will panic/drop if no compliant provider found)
ENFORCE_STRICT_ROUTING=true

# ------------------------------------------------------------------------------
# SECTION 7: CLOUD PROVIDERS (NODE A / B / C)
# ------------------------------------------------------------------------------

DEEPSEEK_API_KEY=your_provider_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

MOONSHOT_API_KEY=your_provider_key_here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

GROQ_API_KEY=your_provider_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

PROVIDERS_CONFIG=config/providers.toml

# ------------------------------------------------------------------------------
# SECTION 8: PHYSICAL FALLBACK (NODE D) - LOCAL INFERENCE
# ------------------------------------------------------------------------------
# SLM activation for when cloud agreement < TMR_MIN_AGREEMENT
SLM_MODEL_ID=serein-slm-v1
SLM_MODEL_PATH=./serein-models/fallback-8b-q4.gguf
SLM_MAX_CONTEXT_TOKENS=8192

# ------------------------------------------------------------------------------
# SECTION 9: NETWORK TOPO & PROXY STEERING (SRE-LEVEL TRAFFIC CONTROL)
# ------------------------------------------------------------------------------
# Global Proxy Toggle: Set to true if running behind a corporate/regional firewall
PROXY_ENABLED=true

# Steering Policy: [latency | round-robin | cost-optimized | sticky]
# 'latency' will probe node health and steer to the fastest responding endpoint
PROXY_STEERING_POLICY=latency

# Proxy Endpoint Configuration (SOCKS5 preferred for Rust/Tokio performance)
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897

# Bypass proxy for domestic API endpoints to ensure lowest latency
NO_PROXY=localhost,127.0.0.1,internal.serein.local,api.moonshot.cn,api.deepseek.com,api.siliconflow.cn

# DNS Resolution Strategy: [system | trust-dns | doh]
# 'trust-dns' is recommended for Rust to avoid blocking glibc getaddrinfo calls
DNS_RESOLVER_STRATEGY=trust-dns

# TCP Connection Pool Fine-tuning
# Time-to-live for a connection in the pool (seconds)
TCP_KEEPALIVE=60
# Connection establishment timeout (milliseconds)
CONNECT_TIMEOUT_MS=5000
# Total request timeout (inclusive of LLM inference time)
TOTAL_REQUEST_TIMEOUT_MS=30000

# Geo-steering Metadata: Helps Oracle module map IP to region for compliance
OWN_NODE_REGION=CN_EAST_1

# ------------------------------------------------------------------------------
# SECTION 10: TMR CONSENSUS ENGINE (SWARM MODULE)
# ------------------------------------------------------------------------------
# Minimum identical responses required for consensus (Standard TMR = 2)
TMR_AGREEMENT_THRESHOLD=2

# Hard timeout for LLM inference before triggering Stasis fallback (milliseconds)
TMR_GLOBAL_TIMEOUT_MS=15000

# Base wait time for jittered exponential backoff on rate limits (milliseconds)
TMR_JITTER_BACKOFF_BASE_MS=200

# ------------------------------------------------------------------------------
# SECTION 11: WASM SANDBOX CONSTRAINTS (AEGIS MODULE)
# ------------------------------------------------------------------------------
# Hard memory limit per tenant WASM instance (Triggers OOM kill)
WASM_MAX_MEMORY_MB=128

# CPU instruction quota to prevent infinite loops (approx 50ms compute)
WASM_INSTRUCTION_LIMIT=50000000

# ------------------------------------------------------------------------------
# SECTION 12: OPENTELEMETRY & TRACING
# ------------------------------------------------------------------------------
# Local OTLP collector endpoint for telemetry and tracing
OTLP_ENDPOINT=http://127.0.0.1:4317

# Tracing sample rate: 1.0 for dev full capture, 0.01 for production
TELEMETRY_SAMPLE_RATE=1.0
